# Optional custom endpoint. Leave empty on Vercel to use the same-origin /api/sync function.
VITE_SYNC_ENDPOINT=

# Optional shared key if you set SYNC_API_KEY on the server. This is visible in the browser bundle.
VITE_SYNC_API_KEY=

# Server-only Vercel/Upstash env vars. These are injected by the Vercel Upstash KV integration.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=
REDIS_URL=
SYNC_API_KEY=
